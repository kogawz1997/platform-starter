generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  CLOSED
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
  LOCKED
}

enum SessionType {
  MEMBER
  ADMIN
}

enum VerificationType {
  EMAIL
  PHONE
  PASSWORD_RESET
  TWO_FACTOR
}

enum SiteSettingGroup {
  WEBSITE
  BRANDING
  THEME
  SEO
  CONTACT
  MAINTENANCE
  SCRIPTS
  FEATURES
  LEGAL
}

enum SiteSettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  URL
  COLOR
  RICH_TEXT
}

enum WalletStatus {
  ACTIVE
  LOCKED
  CLOSED
}

enum WalletLedgerType {
  ADJUSTMENT
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  BONUS
  REVERSAL
}

enum WalletLedgerDirection {
  CREDIT
  DEBIT
}

enum TopUpRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WithdrawalRequestStatus {
  PENDING
  COMPLETED
  REJECTED
  CANCELLED
}

enum BankAccountStatus {
  ACTIVE
  DISABLED
  PENDING_REVIEW
  REJECTED
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  username        String     @unique @db.VarChar(50)
  phone           String?    @unique @db.VarChar(30)
  email           String?    @unique @db.VarChar(255)
  passwordHash    String     @map("password_hash")
  status          UserStatus @default(ACTIVE)
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  profile            UserProfile?
  sessions           AuthSession[]
  loginHistory       LoginHistory[]
  wallet             Wallet?
  walletLedgers      WalletLedger[]
  topUpRequests      TopUpRequest[]
  withdrawalRequests WithdrawalRequest[]
  bankAccounts       MemberBankAccount[]

  @@map("users")
}

model UserProfile {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @unique @map("user_id") @db.Uuid
  displayName String?   @map("display_name") @db.VarChar(100)
  avatarUrl   String?   @map("avatar_url")
  birthday    DateTime?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AdminUser {
  id               String      @id @default(uuid()) @db.Uuid
  username         String      @unique @db.VarChar(50)
  email            String      @unique @db.VarChar(255)
  passwordHash     String      @map("password_hash")
  status           AdminStatus @default(ACTIVE)
  twoFactorEnabled Boolean     @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?     @map("two_factor_secret")
  lastLoginAt      DateTime?   @map("last_login_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  roles               AdminUserRole[]
  sessions            AuthSession[]
  loginHistory        LoginHistory[]
  auditLogs           AdminAuditLog[]
  walletLedgerEntries WalletLedger[]
  reviewedTopUps      TopUpRequest[]
  reviewedWithdrawals WithdrawalRequest[]

  @@map("admin_users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(80)
  name        String   @db.VarChar(100)
  description String?
  level       Int      @default(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  adminUsers  AdminUserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(120)
  name        String   @db.VarChar(120)
  module      String   @db.VarChar(80)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@map("permissions")
}

model AdminUserRole {
  adminUserId String   @map("admin_user_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminUserId, roleId])
  @@map("admin_user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuthSession {
  id               String      @id @default(uuid()) @db.Uuid
  type             SessionType
  userId           String?     @map("user_id") @db.Uuid
  adminUserId      String?     @map("admin_user_id") @db.Uuid
  refreshTokenHash String      @map("refresh_token_hash")
  ipAddress        String?     @map("ip_address") @db.VarChar(64)
  userAgent        String?     @map("user_agent")
  deviceId         String?     @map("device_id") @db.VarChar(120)
  expiresAt        DateTime    @map("expires_at")
  revokedAt        DateTime?   @map("revoked_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminUserId])
  @@map("auth_sessions")
}

model LoginHistory {
  id          String      @id @default(uuid()) @db.Uuid
  type        SessionType
  userId      String?     @map("user_id") @db.Uuid
  adminUserId String?     @map("admin_user_id") @db.Uuid
  success     Boolean
  ipAddress   String?     @map("ip_address") @db.VarChar(64)
  userAgent   String?     @map("user_agent")
  reason      String?
  createdAt   DateTime    @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminUserId])
  @@map("login_history")
}

model VerificationToken {
  id        String           @id @default(uuid()) @db.Uuid
  type      VerificationType
  target    String           @db.VarChar(255)
  tokenHash String           @map("token_hash")
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now())

  @@index([target, type])
  @@map("verification_tokens")
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  adminUserId String?  @map("admin_user_id") @db.Uuid
  action      String   @db.VarChar(120)
  module      String   @db.VarChar(80)
  targetId    String?  @map("target_id") @db.VarChar(120)
  oldData     Json?    @map("old_data")
  newData     Json?    @map("new_data")
  ipAddress   String?  @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now())

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([module, action])
  @@map("admin_audit_logs")
}

model Wallet {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @unique @map("user_id") @db.Uuid
  currency      String       @default("THB") @db.VarChar(10)
  balance       Decimal      @default(0) @db.Decimal(18, 2)
  lockedBalance Decimal      @default(0) @map("locked_balance") @db.Decimal(18, 2)
  status        WalletStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgers WalletLedger[]

  @@index([status])
  @@map("wallets")
}

model WalletLedger {
  id               String                @id @default(uuid()) @db.Uuid
  walletId         String                @map("wallet_id") @db.Uuid
  userId           String                @map("user_id") @db.Uuid
  type             WalletLedgerType
  direction        WalletLedgerDirection
  amount           Decimal               @db.Decimal(18, 2)
  balanceBefore    Decimal               @map("balance_before") @db.Decimal(18, 2)
  balanceAfter     Decimal               @map("balance_after") @db.Decimal(18, 2)
  referenceType    String?               @map("reference_type") @db.VarChar(80)
  referenceId      String?               @map("reference_id") @db.VarChar(120)
  idempotencyKey   String?               @unique @map("idempotency_key") @db.VarChar(160)
  metadata         Json?
  createdByAdminId String?               @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at")

  wallet         Wallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdByAdmin AdminUser? @relation(fields: [createdByAdminId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([userId, createdAt])
  @@index([type])
  @@index([referenceType, referenceId])
  @@map("wallet_ledgers")
}

model TopUpRequest {
  id            String             @id @default(uuid()) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  amount        Decimal            @db.Decimal(18, 2)
  currency      String             @default("THB") @db.VarChar(10)
  status        TopUpRequestStatus @default(PENDING)
  method        String?            @db.VarChar(80)
  referenceCode String?            @map("reference_code") @db.VarChar(120)
  note          String?
  adminNote     String?            @map("admin_note")
  reviewedBy    String?            @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?          @map("reviewed_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer AdminUser? @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([reviewedBy])
  @@map("top_up_requests")
}

model WithdrawalRequest {
  id            String                  @id @default(uuid()) @db.Uuid
  userId        String                  @map("user_id") @db.Uuid
  amount        Decimal                 @db.Decimal(18, 2)
  currency      String                  @default("THB") @db.VarChar(10)
  status        WithdrawalRequestStatus @default(PENDING)
  method        String?                 @db.VarChar(80)
  accountName   String?                 @map("account_name") @db.VarChar(160)
  accountNumber String?                 @map("account_number") @db.VarChar(160)
  bankName      String?                 @map("bank_name") @db.VarChar(160)
  note          String?
  adminNote     String?                 @map("admin_note")
  reviewedBy    String?                 @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?               @map("reviewed_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer AdminUser? @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([reviewedBy])
  @@map("withdrawal_requests")
}

model ReceivingBankAccount {
  id            String            @id @default(uuid()) @db.Uuid
  bankName      String            @map("bank_name") @db.VarChar(120)
  accountName   String            @map("account_name") @db.VarChar(160)
  accountNumber String            @map("account_number") @db.VarChar(160)
  promptPay     String?           @map("prompt_pay") @db.VarChar(160)
  qrImageUrl    String?           @map("qr_image_url")
  minAmount     Decimal?          @map("min_amount") @db.Decimal(18, 2)
  maxAmount     Decimal?          @map("max_amount") @db.Decimal(18, 2)
  status        BankAccountStatus @default(ACTIVE)
  sortOrder     Int               @default(100) @map("sort_order")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([status])
  @@map("receiving_bank_accounts")
}

model MemberBankAccount {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  bankName      String            @map("bank_name") @db.VarChar(120)
  accountName   String            @map("account_name") @db.VarChar(160)
  accountNumber String            @map("account_number") @db.VarChar(160)
  isPrimary     Boolean           @default(false) @map("is_primary")
  status        BankAccountStatus @default(PENDING_REVIEW)
  adminNote     String?           @map("admin_note")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("member_bank_accounts")
}

model SiteSetting {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique @db.VarChar(160)
  valueJson   Json             @map("value_json")
  group       SiteSettingGroup
  type        SiteSettingType  @default(JSON)
  isPublic    Boolean          @default(false) @map("is_public")
  isSensitive Boolean          @default(false) @map("is_sensitive")
  updatedBy   String?          @map("updated_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([group])
  @@index([isPublic])
  @@map("site_settings")
}

model SiteSettingHistory {
  id           String   @id @default(uuid()) @db.Uuid
  settingKey   String   @map("setting_key") @db.VarChar(160)
  oldValueJson Json?    @map("old_value_json")
  newValueJson Json?    @map("new_value_json")
  changedBy    String?  @map("changed_by") @db.Uuid
  ipAddress    String?  @map("ip_address") @db.VarChar(64)
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now())

  @@index([settingKey])
  @@index([changedBy])
  @@map("site_setting_histories")
}
